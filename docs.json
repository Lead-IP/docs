    "primary": "#001ce0",
    "light": "#e3f307",
    "dark": "#001ce0"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "authentication",
              "webhooks",
              "examples"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Contacts",
            "pages": [
              "api-reference/contacts/list",
              "api-reference/contacts/create",
              "api-reference/contacts/get",
              "api-reference/contacts/update"
            ]
          },
          {
            "group": "Lists",
            "pages": [
              "api-reference/lists/list",
              "api-reference/lists/create",
              "api-reference/lists/add-contacts"
            ]
          },
          {
            "group": "Prospects",
            "pages": [
              "api-reference/prospects/search",
              "api-reference/prospects/save"
            ]
          },
          {
            "group": "Campaigns",
            "pages": [
              "api-reference/campaigns/list",
              "api-reference/campaigns/create",
              "api-reference/campaigns/start"
            ]
          },
          {
            "group": "Lexi AI",
            "pages": [
              "api-reference/lexi/chat",
              "api-reference/lexi/tasks",
              "api-reference/lexi/approve",
              "api-reference/lexi/dismiss"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://leadlex.com",
          "icon": "globe"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@leadlex.com",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://leadlex.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@leadlex.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.leadlex.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude"
